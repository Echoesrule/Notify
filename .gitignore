cd C:\.vscode\notify

# Create a comprehensive .gitignore
@"
# Environment files
.env
.env.*
!.env.example
*.env
*.env.local
*.env.production

# Database files
*.sql
*.dump
*.db
*.sqlite

# Uploads and user files
uploads/
backend/uploads/
frontend/uploads/

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/
scripts/node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Secrets and keys
*.pem
*.key
*.crt
.secret

# Build files
dist/
build/
*.min.js

# Package lock files (optional, but can keep)
package-lock.json
backend/package-lock.json
"@ | Out-File -FilePath .gitignore -Encoding UTF8

# Add to git
git add .gitignore
git commit -m "Update .gitignore to protect sensitive files"